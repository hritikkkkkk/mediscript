{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Patient demographic and clinical data",
      "type": "object",
      "properties": {
        "doctor_id": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "weight": { "type": "number" },
        "blood_group": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "conditions": { "type": "array", "items": { "type": "string" } },
        "last_visited": { "type": "string", "format": "date-time" }
      },
      "required": ["doctor_id", "name"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Patient medical prescription",
      "type": "object",
      "properties": {
        "doctor_id": { "type": "string" },
        "patient_id": { "type": "string" },
        "diagnosis": { "type": "string" },
        "notes": { "type": "string" },
        "follow_up_date": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["doctor_id", "patient_id"]
    },
    "PrescriptionItem": {
       "title": "Prescription Item",
       "description": "Individual medication in a prescription",
       "type": "object",
       "properties": {
         "prescription_id": { "type": "string" },
         "medicine_name": { "type": "string" },
         "salt": { "type": "string" },
         "dosage": { "type": "string" },
         "frequency": { "type": "string" },
         "duration": { "type": "string" },
         "timing": { "type": "string" },
         "type": { "type": "string" }
       }
    },
    "Medicine": {
      "title": "Medicine",
      "description": "Global medicine database",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "salt": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "Reminder": {
      "title": "Reminder",
      "description": "Clinical follow-up reminder",
      "type": "object",
      "properties": {
        "doctor_id": { "type": "string" },
        "patient_id": { "type": "string" },
        "patient_name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["doctor_id", "patient_id", "date"]
    }
  },
  "firestore": {
    "/patients": {
      "schema": "Patient",
      "description": "Collection of patients"
    },
    "/prescriptions": {
      "schema": "Prescription",
      "description": "Collection of prescriptions"
    },
    "/prescription_items": {
      "schema": "PrescriptionItem",
      "description": "Sub-items for prescriptions"
    },
    "/medicines": {
      "schema": "Medicine",
      "description": "Master list of medicines"
    },
    "/reminders": {
      "schema": "Reminder",
      "description": "Follow-up reminders"
    }
  }
}
